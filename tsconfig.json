{
  "ts-node": {
    "require": ["tsconfig-paths/register", "dotenv/config"]
  },
  "tsc-alias": {
    "resolveFullPaths": true
  },
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["./types/global"],
    "baseUrl": ".",
    "paths": {
      "@prisma-generated/*": ["generated/prisma/*"],
      "@config/*": ["src/config/*"],
      "@middleware/*": ["src/middlewares/*"],
      "@module/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@util/*": ["src/utils/*"]
    }
  },
  "include": ["src", "generated"],
  "exclude": ["node_modules", "dist"]
}
